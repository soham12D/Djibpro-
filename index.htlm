<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Joyeux Anniversaire Hamdi</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial', sans-serif; }
        body { background-color: #ffe4e1; overflow: hidden; }
        
        .container {
            height: 100vh;
            width: 100vw;
            overflow-y: scroll;
            scroll-snap-type: y mandatory;
            scroll-behavior: smooth;
        }

        section {
            height: 100vh;
            width: 100vw;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            scroll-snap-align: start;
            text-align: center;
            padding: 20px;
            position: relative;
        }

        /* Page 1: Accueil */
        .page1 { background: linear-gradient(#ff9a9e, #fad0c4); }
        .bear-box { font-size: 80px; margin-bottom: 20px; }

        /* Page 2: Gâteau Géant */
        .page2 { background: #ffffff; }
        .cake { font-size: 150px; cursor: pointer; transition: transform 0.3s; }
        .cake:active { transform: scale(1.2); }

        /* Page 3: Lettre et Photos */
        .page3 { 
            background: #ffe4e1; 
            display: block; 
            overflow-y: auto;
            padding: 40px 10px;
        }
        .letter {
            background: white;
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            max-width: 95%;
            margin: 0 auto 30px auto;
            line-height: 1.6;
            color: #d63384;
        }
        .photo-grid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            padding-bottom: 50px;
        }
        .photo-grid img {
            width: 90%;
            max-width: 400px;
            border-radius: 15px;
            border: 8px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        h1 { color: #d63384; margin-bottom: 15px; font-size: 28px; }
        .hint { position: absolute; bottom: 20px; font-size: 14px; color: #fff; animation: bounce 2s infinite; }
        @keyframes bounce { 0%, 20%, 50%, 80%, 100% {transform: translateY(0);} 40% {transform: translateY(-10px);} 60% {transform: translateY(-5px);} }
    </style>
</head>
<body>

<div class="container" id="main-container">
    
    <section class="page1">
        <div class="bear-box">🧸❤️🧸</div>
        <h1 style="color: white;">Coucou mon bébé...</h1>
        <p style="color: white; font-size: 18px;">Glisse vers le haut pour ta surprise</p>
        <div class="hint">↑ Swipe vers le haut ↑</div>
    </section>

    <section class="page2" id="cake-section">
        <div class="cake" onclick="launchConfetti()">🎂</div>
        <h1 style="font-size: 45px;">JOYEUX ANNIVERSAIRE !</h1>
        <p style="color: #666;">(Touche le gâteau !)</p>
        <div class="hint" style="color: #d63384;">Encore un petit swipe... ↑</div>
    </section>

    <section class="page3">
        <div class="letter">
            <h1>À Hamdi, mon amour</h1>
            <p>Mon cœur, pour tes 27 ans, je voulais te dire à quel point tu es spécial pour moi. Chaque jour à tes côtés est un cadeau, et je suis tellement fière de l'homme que tu es. Que cette année t'apporte autant de bonheur que celui que tu m'offres.</p>
            <br>
            <p style="font-size: 20px; font-weight: bold;">Hamdi mon amour, à tes 27 ans et à tous ceux qu'on fêtera ensemble. Je t'aime infiniment.</p>
        </div>
        
        <div class="photo-grid">
            <img src="https://i.postimg.cc/4nsMwKcH/3a994eb7-c943-43d4-a51d-c5e00d3911f9.jpg" alt="Photo 1">
            <img src="https://i.postimg.cc/Bjr7Ftsb/IMG-2653.jpg" alt="Photo 2">
            <img src="https://i.postimg.cc/JGyQQmpc/IMG-2715.png" alt="Photo 3">
            <img src="https://i.postimg.cc/MvGL2hdq/IMG-4726.jpg" alt="Photo 4">
            <img src="https://i.postimg.cc/8fmZQbrr/IMG-5430.jpg" alt="Photo 5">
        </div>
    </section>

</div>

<script>
    const container = document.getElementById('main-container');
    const cakeSection = document.getElementById('cake-section');
    let fired = false;

    // Déclenche les confettis automatiquement au swipe
    container.addEventListener('scroll', () => {
        const sectionTop = cakeSection.getBoundingClientRect().top;
        if (sectionTop < window.innerHeight / 2 && !fired) {
            launchConfetti();
            fired = true;
        }
    });

    function launchConfetti() {
        var duration = 3 * 1000;
        var end = Date.now() + duration;

        (function frame() {
          confetti({
            particleCount: 7,
            angle: 60,
            spread: 55,
            origin: { x: 0, y: 0.7 },
            colors: ['#ff9a9e', '#d63384', '#ffffff']
          });
          confetti({
            particleCount: 7,
            angle: 120,
            spread: 55,
            origin: { x: 1, y: 0.7 },
            colors: ['#ff9a9e', '#d63384', '#ffffff']
          });

          if (Date.now() < end) {
            requestAnimationFrame(frame);
          }
        }());
    }
</script>

</body>
</html>
